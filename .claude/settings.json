{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-quality.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/level-typecheck.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/coordinate-validator.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/performance-sentinel.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/level-build-verify.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
