    "src/r3f/entities/EnemyMesh.tsx",
    "src/r3f/entities/EnemySystem.ts",
    "src/r3f/weapons/WeaponSystem.ts",
    "src/r3f/weapons/ProjectilePool.ts",
    "src/r3f/audio/index.ts",
    "src/r3f/input/InputManager.ts",
    "src/r3f/input/InputActions.ts",
    "src/r3f/systems/CombatSystem.ts",
    "src/r3f/systems/ParticleEffects.ts",
    "src/r3f/rendering/index.ts",
    "src/r3f/xr/index.ts",
    "src/state/GameStore.ts",
