{
  "name": "enemy",
  "description": "Enemy pipeline: concept → preview → refine → rigging → animations. Only downloads final animation GLBs (skipArtifacts on all intermediate steps).",
  "version": "1.0.0",
  "steps": [
    {
      "id": "concept",
      "task": "text-to-image",
      "skipArtifacts": true,
      "inputs": [
        { "name": "prompt", "source": "manifest", "path": "textToImageTask.prompt" },
        { "name": "ai_model", "source": "literal", "value": "nano-banana-pro" },
        {
          "name": "generate_multi_view",
          "source": "manifest",
          "path": "textToImageTask.generateMultiView",
          "default": true
        },
        {
          "name": "pose_mode",
          "source": "manifest",
          "path": "textToImageTask.poseMode",
          "default": "a-pose"
        }
      ]
    },
    {
      "id": "preview",
      "task": "text-to-3d-preview",
      "dependsOn": ["concept"],
      "skipArtifacts": true,
      "inputs": [
        { "name": "prompt", "source": "manifest", "path": "textTo3DPreviewTask.prompt" },
        {
          "name": "art_style",
          "source": "manifest",
          "path": "textTo3DPreviewTask.artStyle",
          "default": "realistic"
        },
        {
          "name": "target_polycount",
          "source": "manifest",
          "path": "textTo3DPreviewTask.targetPolycount",
          "default": 10000
        },
        {
          "name": "topology",
          "source": "manifest",
          "path": "textTo3DPreviewTask.topology",
          "default": "quad"
        },
        {
          "name": "should_remesh",
          "source": "manifest",
          "path": "textTo3DPreviewTask.shouldRemesh",
          "default": true
        },
        {
          "name": "symmetry_mode",
          "source": "manifest",
          "path": "textTo3DPreviewTask.symmetryMode",
          "default": "auto"
        }
      ]
    },
    {
      "id": "refine",
      "task": "text-to-3d-refine",
      "dependsOn": ["preview"],
      "skipArtifacts": true,
      "inputs": [
        { "name": "preview_task_id", "source": "step", "step": "preview", "path": "taskId" },
        {
          "name": "texture_prompt",
          "source": "manifest",
          "path": "textTo3DRefineTask.texturePrompt"
        },
        {
          "name": "enable_pbr",
          "source": "manifest",
          "path": "textTo3DRefineTask.enablePbr",
          "default": true
        }
      ]
    },
    {
      "id": "rigging",
      "task": "rigging",
      "dependsOn": ["refine"],
      "skipArtifacts": true,
      "inputs": [
        { "name": "input_task_id", "source": "step", "step": "refine", "path": "taskId" },
        {
          "name": "height_meters",
          "source": "manifest",
          "path": "riggingTask.heightMeters",
          "default": 1.8
        }
      ]
    },
    {
      "id": "animations",
      "task": "animation",
      "dependsOn": ["rigging"],
      "forEach": {
        "source": "manifest",
        "path": "animationTask.animations",
        "as": "animationName"
      },
      "inputs": [{ "name": "rig_task_id", "source": "step", "step": "rigging", "path": "taskId" }]
    }
  ]
}
